{
  "name": "@campusqr/api",
  "version": "1.0.0",
  "description": "Smart QR-Based Campus Management System",
  "main": "server/index.js",
  "scripts": {
    "start": "node -r dotenv/config server/index.js",
    "dev": "node --watch server/index.js",
    "seed": "node database/seed.js",
    "setup": "pnpm install && pnpm seed",
    "build": "node scripts/check-syntax.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "node scripts/check-syntax.mjs",
    "postinstall": "node scripts/ensure-dirs.mjs"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.16.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@campusqr/config": "workspace:*",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "vitest": "^2.1.8"
  }
}
